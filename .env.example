# Copie este arquivo para .env:
#   cp .env.example .env
#
# Todos os valores abaixo já funcionam em localhost sem alteração.

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------

MONGO_URI=mongodb://admin:admin123@localhost:27017/

# ---------------------------------------------------------------------------
# Ingestão (ingest/ingest.py)
# ---------------------------------------------------------------------------

# Caminho para o ffmpeg instalado via WinGet no Windows
FFMPEG_PATH=C:\Users\groun\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe

# Número de downloads simultâneos
MAX_WORKERS=6

# ---------------------------------------------------------------------------
# Extração de features (dsp/extract_features.py)
# ---------------------------------------------------------------------------

# Salvar o parquet a cada N faixas extraídas (checkpoint anti-interrupção)
CHECKPOINT_EVERY=50

# Labels (gêneros) a incluir na extração — separados por vírgula, sem espaços
# Vazio = todos os gêneros presentes no banco (padrão)
# Exemplo: LABELS=metalcore,nu_metal,pop
LABELS=

# Estratégia de balanceamento de classes antes da extração:
#   none        — processa todas as faixas (padrão)
#   undersample — limita todas as classes ao tamanho da menor (cap = min)
#   balance     — limita classes acima da mediana ao valor da mediana;
#                 classes menores ficam intactas
BALANCE_STRATEGY=none

# ---------------------------------------------------------------------------
# Backup/restore (ingest/mongo_crud.py dump | restore)
# ---------------------------------------------------------------------------

# Caminhos para o MongoDB Database Tools (instalado em Program Files)
MONGODUMP_PATH=C:\Program Files\MongoDB\Tools\100\bin\mongodump.exe
MONGORESTORE_PATH=C:\Program Files\MongoDB\Tools\100\bin\mongorestore.exe
